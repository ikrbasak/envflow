{
  "name": "@ikrbasak/envflow",
  "version": "0.0.0",
  "description": "Type-safe, NODE_ENV-aware environment loader for Node.",
  "keywords": [
    "12factor",
    "config",
    "dotenv",
    "env",
    "environment",
    "node_env"
  ],
  "homepage": "https://github.com/ikrbasak/envflow#readme",
  "bugs": {
    "url": "https://github.com/ikrbasak/envflow/issues"
  },
  "license": "MIT",
  "author": "Krishna Basak",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ikrbasak/envflow.git"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./config": {
      "import": {
        "types": "./dist/config.d.mts",
        "default": "./dist/config.mjs"
      },
      "require": {
        "types": "./dist/config.d.cts",
        "default": "./dist/config.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "lint": "oxlint",
    "lint:types": "oxlint --type-aware",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check": "pnpm lint && pnpm format:check && pnpm typecheck && pnpm test:coverage && pnpm build",
    "release": "pnpm build && changeset publish",
    "changeset": "changeset",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "oxlint-tsgolint": "^0.23.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "lint-staged": {
    "*.{ts,js,json,md,yml,yaml}": [
      "oxfmt"
    ],
    "*.{ts,js}": [
      "oxlint --fix"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.4.0"
}
